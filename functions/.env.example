# Backend-only reminder delivery configuration
# Copy this file to functions/.env for emulator work or set equivalent values
# in Firebase Functions runtime config / secret management for production.

EMAIL_PROVIDER=resend
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=MedTrack
MEDTRACK_CLINIC_NAME=MedTrack Immunization Clinic
RESEND_API_KEY=replace-with-backend-secret

SMS_PROVIDER=console
MEDTRACK_SMS_SENDER=MedTrack
TERMII_API_KEY=replace-with-backend-secret
TERMII_SENDER_ID=MedTrack
TWILIO_ACCOUNT_SID=replace-with-backend-secret
TWILIO_AUTH_TOKEN=replace-with-backend-secret
TWILIO_FROM_NUMBER=+10000000000
